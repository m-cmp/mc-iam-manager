## Default Workspace
DEFAULT_WORKSPACE_NAME=ws01

TEMPORARY_SECURITY_CREDENTIALS_ENDPOINT_AWS=https://sts.amazonaws.com
AWS_ACCOUNT_ID=050864702683
CSP_ROLE_PREFIX=mciam
IDENTITY_PROVIDER_ARN_AWS=arn:aws:iam::${AWS_ACCOUNT_ID}:oidc-provider/${MC_IAM_MANAGER_KEYCLOAK_EXTERNAL_DOMAIN}/auth/realms/${MC_IAM_MANAGER_KEYCLOAK_REALM}
IDENTITY_ROLE_ARN_AWS=arn:aws:iam::${AWS_ACCOUNT_ID}:role/${CSP_ROLE_PREFIX}-platformadmin

# SAML Client ID (CSP별 Keycloak SAML 클라이언트 ID)
SAML_CLIENT_ID_AWS=urn:amazon:webservices
SAML_CLIENT_ID_ALIBABA=urn:alibaba:cloudcomputing

# ── 통합 테스트 변수 (INTEGRATION_TEST=1 시 사용) ─────────────────────────────
# SAML assertion 발급에 필요한 platformAdmin 계정 (GetSamlAssertionByServiceAccount 내부 사용)
TEST_PLATFORMADMIN_ID=mcmp
TEST_PLATFORMADMIN_PASSWORD=mcmp_password
# AWS OIDC
TEST_AWS_OIDC_PROVIDER_ARN=arn:aws:iam::${AWS_ACCOUNT_ID}:oidc-provider/${MC_IAM_MANAGER_KEYCLOAK_EXTERNAL_DOMAIN}/auth/realms/${MC_IAM_MANAGER_KEYCLOAK_REALM}
TEST_AWS_OIDC_ROLE_ARN=arn:aws:iam::${AWS_ACCOUNT_ID}:role/${CSP_ROLE_PREFIX}-platformadmin
# AWS SAML (AWS IAM Console → Identity providers에서 실제 등록된 ARN으로 채울 것)
TEST_AWS_SAML_PROVIDER_ARN=notyet
TEST_AWS_SAML_ROLE_ARN=notyet
TEST_KC_SAML_CLIENT_ID=${SAML_CLIENT_ID_AWS}
# Alibaba SAML
TEST_ALIBABA_SAML_PROVIDER_ARN=notyet
TEST_ALIBABA_SAML_ROLE_ARN=notyet
TEST_KC_ALIBABA_SAML_CLIENT_ID=${SAML_CLIENT_ID_ALIBABA}
# Alibaba OIDC
TEST_ALIBABA_OIDC_PROVIDER_ARN=notyet
TEST_ALIBABA_OIDC_ROLE_ARN=notyet
# GCP SAML (projects/PROJECT_NUM/locations/global/workloadIdentityPools/POOL/providers/SAML_PROVIDER 형식)
TEST_GCP_WIF_PROVIDER=notyet
TEST_GCP_SERVICE_ACCOUNT_EMAIL=notyet
TEST_KC_GCP_SAML_CLIENT_ID=notyet
# Azure OIDC
TEST_AZURE_TENANT_ID=notyet
TEST_AZURE_CLIENT_ID=notyet
# Tencent SAML (CAM secret key + ARN)
TEST_TENCENT_SECRET_ID=notyet
TEST_TENCENT_SECRET_KEY=notyet
TEST_TENCENT_ROLE_ARN=notyet
TEST_TENCENT_PRINCIPAL_ARN=notyet
TEST_KC_TENCENT_SAML_CLIENT_ID=notyet
# IBM OIDC (Trusted Profile ID)
TEST_IBM_PROFILE_ID=notyet